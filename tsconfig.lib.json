{
  "comment": "Optional: emit the framework-agnostic engine core as a distributable library (npm run lib:build).",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "sourceMap": true,
    "noEmit": false,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
