{
  "name": "basketballmanager",
  "version": "0.1.0",
  "description": "International basketball manager — deterministic possession-based match engine, roster-quota validation, and a mobile-first manager UI.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lib:build": "tsc -p tsconfig.lib.json",
